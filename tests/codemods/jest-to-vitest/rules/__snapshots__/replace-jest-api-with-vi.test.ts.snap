// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`EUA-style jest.mock factories > keeps requireActual object mocks explicit without global helpers 1`] = `
"import { openModalAction } from 'components/core/modal/actions';

vi.mock('components/core/modal/actions', async () => {
  const actual = (await vi.importActual('components/core/modal/actions'));
  const mockedModule = {
    ...actual,
    openModalAction: vi.fn(function(payload) {
      return ({ type: actual.openModalAction.toString(), payload });
    }),
  }; return { ...mockedModule, default: mockedModule };
});"
`;

exports[`compatibility fixes > adds advanceTimers to userEvent setup in fake-timer files 1`] = `
"vi.useFakeTimers();

    test('hovers', async () => {
      const user = userEvent.setup({ delay: null, advanceTimers: vi.advanceTimersByTime });
    });"
`;

exports[`compatibility fixes > awaits resetModules helper calls in test files 1`] = `
"const resetModulesAndMockEnvironment = async () => {
      return (await import('../selectors'));
    };

    test('uses helper', async () => {
      const { getAppFeature: getAppFeatureProd } = await resetModulesAndMockEnvironment('prod');
      expect(getAppFeatureProd).toBeDefined();
    });"
`;

exports[`compatibility fixes > cache busts expected failing dynamic imports 1`] = `
"describe('mainAfterPolyfill', () => {
      test('first import', async () => {
        await expect(import('../mainAfterPolyfill?vitest-expected-error')).rejects.toThrowError('boom');
      });

      test('second import', async () => {
        await import('../mainAfterPolyfill');
await vi.dynamicImportSettled()
      });
    });"
`;

exports[`compatibility fixes > pairs vi.resetModules with vi.clearAllMocks 1`] = `
"beforeEach(() => {
      vi.resetModules(); vi.clearAllMocks();
    });"
`;

exports[`compatibility fixes > rewrites auto-mocked export reassignments to vi.mocked calls 1`] = `
