      render: mockRender,
    });"
`;

exports[`compatibility fixes > uses async timer flushing in async fake-timer tests 1`] = `
"vi.useFakeTimers();

    test('flushes timers', async () => {
      await vi.runAllTimersAsync();
    });"
`;

exports[`compatibility fixes > uses vi.waitFor in fake-timer files 1`] = `
