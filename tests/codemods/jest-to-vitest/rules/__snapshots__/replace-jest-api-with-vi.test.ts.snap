`;

exports[`convertMockImplArrowToFunction > converts async arrow function to async regular function 1`] = `"mockFn.mockImplementation(async function(arg) { return doSomething(arg); })"`;

exports[`convertMockImplArrowToFunction > converts mockImplementation block-body arrow to regular function 1`] = `"mockFn.mockImplementation(function(arg) { return doSomething(arg); })"`;

exports[`convertMockImplArrowToFunction > converts mockImplementation expression-body arrow to regular function 1`] = `"mockFn.mockImplementation(function(arg) { return doSomething(arg); })"`;

exports[`convertMockImplArrowToFunction > converts mockImplementationOnce arrow to regular function 1`] = `"mockFn.mockImplementationOnce(function(arg) { return doSomething(arg); })"`;

