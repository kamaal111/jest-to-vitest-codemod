{
  "name": "@kamaalio/jest-to-vitest-codemod",
  "version": "0.0.2",
  "type": "module",
  "author": "Kamaal Farah",
  "repository": "kamaal111/jest-to-vitest-codemod",
  "bugs": "https://github.com/kamaal111/jest-to-vitest-codemod/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "jest-to-vitest-codemod": "./dist/cli.js"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib build",
    "build:clean": "rm -rf dist tsconfig.tsbuildinfo && pnpm build",
    "dev": "rslib build --watch",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint --max-warnings 0",
    "prepare": "husky",
    "test": "vitest run",
    "test:cov": "pnpm install && vitest run --coverage",
    "test:u": "vitest run --update",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "quality": "pnpm install && pnpm lint && pnpm format:check && pnpm type-check"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.41.0",
    "@kamaalio/codemod-kit": "^0.0.42",
    "@kamaalio/kamaal": "^0.8.0",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@kamaalio/prettier-config": "^0.1.2",
    "@rslib/core": "^0.19.6",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*": "prettier --write --ignore-unknown"
  },
  "prettier": "@kamaalio/prettier-config"
}
